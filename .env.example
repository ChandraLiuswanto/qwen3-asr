# Qwen3-ASR environment
# Copy to .env and edit only the values you need to change.

# -----------------------------------------------------------------------------
# Public endpoint and auth.
# -----------------------------------------------------------------------------
# NGINX_PORT controls the host port used by docker-compose.
NGINX_PORT=17003

# Address the server binds to.
#
# HOST is the bind address. 0.0.0.0 accepts connections from anywhere; use
# 127.0.0.1 to accept only local ones. Under Docker, leave it at 0.0.0.0 --
# binding to 127.0.0.1 inside a container makes it unreachable from the host.
#
# PORT is the port the app itself listens on, which is NOT the port you connect
# to under docker-compose. There, you reach the app on NGINX_PORT (17003 above),
# which is forwarded to PORT inside the container. Change PORT only if 8000
# collides with something; change NGINX_PORT to change the address you browse to.
#
# HOST=0.0.0.0
# PORT=8000

# Leave empty to disable authentication.
# API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# Runtime selection.
# -----------------------------------------------------------------------------
# CUDA_VISIBLE_DEVICES=0

# Leave QWEN3_ASR_MODEL empty for automatic selection.
# Supported values: qwen3-asr-0.6b, qwen3-asr-1.7b
# QWEN3_ASR_MODEL=

# -----------------------------------------------------------------------------
# Model cache behavior.
# Default: download missing models at startup.
# -----------------------------------------------------------------------------
# HF_HUB_OFFLINE=1
# HF_ENDPOINT=https://hf-mirror.com

# -----------------------------------------------------------------------------
# Offline ASR batching. Only worth touching if a request produces many
# segments — diarization splits by SPEAKER TURN (min 1s), not by duration, so
# a chatty 2-minute clip can yield far more segments than you'd expect.
#
# Check before tuning; the server logs this per request:
#   grep ASR_STAGE_TIMINGS <server-log>   -> read segments= and batches=
# batches=1 means these are already maxed and there is nothing to gain here.
#
# Effective batch = min(ASR_BATCH_SIZE, ASR_MAX_INFERENCE_BATCH_SIZE, segments)
# -----------------------------------------------------------------------------
# Segments submitted per generate() call. Default 4.
# ASR_BATCH_SIZE=4

# Backend re-chunks each batch by this. Unset = models.json value (16 for the
# qwen3 models), which silently caps ASR_BATCH_SIZE above 16. Raise BOTH to go
# higher. Env wins over models.json.
# ASR_MAX_INFERENCE_BATCH_SIZE=16

# Speaker-embedding batch for diarization. Default 32; higher suits large VRAM.
# DIARIZATION_SV_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Concurrency admission (vLLM/CUDA only). These are CEILINGS, not accelerators
# — raising them queues work inside the service rather than making it faster.
# Set VLLM_OFFLINE_CONCURRENCY=1 to restore fully serialized behavior.
# Invalid values (<1) fail loudly at boot rather than hang.
# -----------------------------------------------------------------------------
# Concurrent offline transcription requests. Default 4.
# VLLM_OFFLINE_CONCURRENCY=4

# Concurrent websocket decodes. Default 4.
# VLLM_WS_DECODE_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Per-model paths.
#
# Point any single model at a directory you control. The path is the model
# directory itself -- the model id is NOT appended:
#
#   MODEL_PATH_VAD=/mnt/models/fsmn-vad     loads /mnt/models/fsmn-vad
#
# A model with an override is never downloaded, and is skipped by the startup
# integrity check (the check assumes cache layout; your directory is flat).
# A path that does not exist, is not a directory, or is empty aborts startup.
# An unrecognized MODEL_PATH_* variable also aborts startup, so typos surface
# immediately instead of silently loading cached weights.
#
# ASR models are named after their key in app/services/asr/models.json,
# uppercased with - and . replaced by _. Adding a model there needs no code
# change: qwen3-asr-1.7b -> MODEL_PATH_QWEN3_ASR_1_7B
#
# MODEL_PATH_QWEN3_ASR_1_7B=
# MODEL_PATH_QWEN3_ASR_0_6B=
# MODEL_PATH_PARAFORMER_LARGE=
# MODEL_PATH_FORCED_ALIGNER=
#
# Support models:
# MODEL_PATH_VAD=
# MODEL_PATH_PUNC=
# MODEL_PATH_PUNC_REALTIME=
# MODEL_PATH_CAMPP_DIARIZATION=
# MODEL_PATH_CAMPP_SV=
# MODEL_PATH_CAMPP_TRANSFORMER=
#
# Docker: an override alone is not enough -- the container cannot see host paths.
# Bind-mount the directory at the SAME path inside the container, e.g. for
# MODEL_PATH_VAD=/mnt/models/fsmn-vad add to docker-compose.yml:
#
#   volumes:
#     - /mnt/models/fsmn-vad:/mnt/models/fsmn-vad:ro
#
# Note: MODEL_PATH_CAMPP_DIARIZATION needs a writable mount (drop :ro) when
# HF_HUB_OFFLINE=1 -- its configuration.json is rewritten for offline use.
#
# --export-dir cannot be combined with overrides; it copies from the caches.
# -----------------------------------------------------------------------------
